---
import AnimateOnScroll from '../shared/AnimateOnScroll.astro';
import ProjectPlaceholder from '../shared/ProjectPlaceholder.astro';

interface Project {
  title: string;
  category: string;
  tags: string[];
  description: string;
  href: string;
  live?: string;
  image?: string;
}

const projects: Project[] = [
  {
    title: "Vidmation",
    category: "AI / Video Automation",
    tags: ["Python", "FastAPI", "Claude API", "FFmpeg"],
    description:
      "End-to-end AI video automation platform. Generates faceless YouTube content with AI narration, captions, and automated publishing.",
    href: "https://github.com/connorodea/vidmation",
    image: "/projects/vidmation.png",
  },
  {
    title: "ClawdHub",
    category: "AI / Developer Tools",
    tags: ["Python", "Textual", "Claude SDK"],
    description:
      "Terminal IDE for spawning and orchestrating multiple Claude Code agents in real time. 13,000 lines, 26 files.",
    href: "https://github.com/connorodea/clawd-hub",
    image: "/projects/clawdhub.png",
  },
  {
    title: "QuickLotz WMS",
    category: "Enterprise / SaaS",
    tags: ["TypeScript", "React", "PostgreSQL"],
    description:
      "Enterprise warehouse management system powering inventory, 3PL logistics, and real-time analytics for circular economy operations.",
    href: "https://github.com/connorodea/upscaled-quicklotz-dashboard",
    live: "https://v0-sourcing-platform-ui.vercel.app",
    image: "/projects/quicklotz-wms.png",
  },
  {
    title: "QuickVisionz",
    category: "AI / Computer Vision",
    tags: ["Python", "YOLO", "OpenCV"],
    description:
      "Computer vision sorting pipeline with YOLO object detection, automated barcode classification, and thermal label printing.",
    href: "https://github.com/connorodea/QuickVisionz",
    image: "/projects/quickvisionz.png",
  },
];
---

<section id="work" class="bg-black py-32 lg:py-40">
  <div class="mx-auto max-w-5xl px-6">
    <AnimateOnScroll animation="fade-up">
      <h2 class="text-4xl font-semibold tracking-tight text-white lg:text-5xl">
        Work
      </h2>
      <p class="mt-4 text-lg text-[#ababab]">Selected projects.</p>
    </AnimateOnScroll>

    <div class="mt-16">
      {projects.map((project) => (
        <AnimateOnScroll animation="fade-up">
          <div class="border-t border-white/10 py-12">
            <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">
              <div>
                <h3 class="text-2xl font-medium text-white">{project.title}</h3>
                <p class="mt-3 leading-relaxed text-[#ababab]">
                  {project.description}
                </p>
                <div class="mt-5 flex flex-wrap gap-2">
                  {project.tags.map((tag) => (
                    <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-[#666]">
                      {tag}
                    </span>
                  ))}
                </div>
                <div class="mt-6 flex items-center gap-4">
                  <a
                    href={project.href}
                    target={project.href.startsWith("http") ? "_blank" : undefined}
                    rel={project.href.startsWith("http") ? "noopener noreferrer" : undefined}
                    class="inline-block text-sm text-[#666] transition-colors duration-200 hover:text-white"
                  >
                    View project &rarr;
                  </a>
                  {project.live && (
                    <a
                      href={project.live}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-block text-sm text-[#10a37f] transition-colors duration-200 hover:text-white"
                    >
                      Live Demo &rarr;
                    </a>
                  )}
                </div>
              </div>
              <div>
                {project.image ? (
                  <img src={project.image} alt={project.title} class="aspect-video w-full rounded-lg object-cover" loading="lazy" />
                ) : (
                  <ProjectPlaceholder title={project.title} category={project.category} rounded="lg" />
                )}
              </div>
            </div>
          </div>
        </AnimateOnScroll>
      ))}
    </div>

    <AnimateOnScroll animation="fade-up">
      <div class="mt-8 border-t border-white/10 pt-12">
        <a
          href="/work"
          class="text-sm text-[#666] transition-colors duration-200 hover:text-white"
        >
          See all projects &rarr;
        </a>
      </div>
    </AnimateOnScroll>
  </div>
</section>
