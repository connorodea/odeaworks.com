---
import AnimateOnScroll from '../shared/AnimateOnScroll.astro';
---

<section class="bg-black py-32 lg:py-40">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <AnimateOnScroll animation="fade-in">
      <p class="text-2xl font-light tracking-tight text-text-secondary lg:text-3xl">
        10+ ventures built. Millions in revenue generated. Systems serving thousands daily.
      </p>
    </AnimateOnScroll>
  </div>
</section>
