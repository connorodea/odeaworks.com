---
interface Metric {
  value: string;
  label: string;
}

const metrics: Metric[] = [
  { value: "10+", label: "Ventures Founded" },
  { value: "50+", label: "Projects Shipped" },
  { value: "13K+", label: "Lines in ClawdHub" },
  { value: "24hr", label: "Response Time" },
];
---

<section class="metrics-section relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4">
      {metrics.map((metric) => (
        <div class="text-center">
          <div class="metric-value text-5xl font-bold">{metric.value}</div>
          <div class="mt-3 text-sm font-medium uppercase tracking-widest text-zinc-500">
            {metric.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .metrics-section {
    background-color: #0c0c0e;
  }

  .metric-value {
    background: linear-gradient(135deg, #6366f1, #06b6d4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>
