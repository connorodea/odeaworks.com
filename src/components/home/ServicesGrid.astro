---
interface Service {
  title: string;
  description: string;
  icon: string;
  iconColor: string;
  glowColor: string;
  link: string;
}

const services: Service[] = [
  {
    title: "AI Consulting & Engineering",
    description:
      "LLM agent systems, autonomous AI pipelines, computer vision, RAG architectures, and ML operations — from prototype to production.",
    icon: "brain",
    iconColor: "#6366f1",
    glowColor: "rgba(99, 102, 241, 0.15)",
    link: "/services/ai",
  },
  {
    title: "Technical Consulting",
    description:
      "Architecture reviews, infrastructure optimization, DevOps strategy, cloud migration, and performance engineering.",
    icon: "gear",
    iconColor: "#06b6d4",
    glowColor: "rgba(6, 182, 212, 0.15)",
    link: "/services/consulting",
  },
  {
    title: "Engineering",
    description:
      "System design, API development, database architecture, CI/CD pipelines, and scalable infrastructure that handles real-world load.",
    icon: "code",
    iconColor: "#6366f1",
    glowColor: "rgba(99, 102, 241, 0.15)",
    link: "/services/engineering",
  },
  {
    title: "Software Development",
    description:
      "Full-stack web applications, SaaS platforms, mobile apps, terminal tools, and automation systems built to ship.",
    icon: "rocket",
    iconColor: "#06b6d4",
    glowColor: "rgba(6, 182, 212, 0.15)",
    link: "/services/development",
  },
];
---

<section class="services-section relative py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Section heading -->
    <div class="mb-16 text-center">
      <h2 class="mb-4 text-3xl font-bold tracking-tight text-white sm:text-4xl md:text-5xl">
        What We <span class="services-gradient-text">Build</span>
      </h2>
      <p class="mx-auto max-w-2xl text-lg text-zinc-400">
        End-to-end AI and software engineering for ambitious companies.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <div
          class="service-card group relative rounded-2xl border p-8 transition-all duration-300"
          style={`--glow-color: ${service.glowColor};`}
        >
          <!-- Icon -->
          <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-xl bg-white/5">
            {service.icon === "brain" && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke={service.iconColor} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a7 7 0 0 0-7 7c0 2.38 1.19 4.47 3 5.74V17a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-2.26c1.81-1.27 3-3.36 3-5.74a7 7 0 0 0-7-7Z" />
                <path d="M10 17v4" />
                <path d="M14 17v4" />
                <path d="M9 10h.01" />
                <path d="M15 10h.01" />
                <path d="M12 2v3" />
                <path d="M8 5.5 6.5 4" />
                <path d="M16 5.5 17.5 4" />
                <circle cx="9" cy="10" r="0.5" fill={service.iconColor} stroke="none" />
                <circle cx="15" cy="10" r="0.5" fill={service.iconColor} stroke="none" />
                <path d="M9 13c1 1.333 2 1.333 3 0" />
                <path d="M12 13c1 1.333 2 1.333 3 0" />
              </svg>
            )}
            {service.icon === "gear" && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke={service.iconColor} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            )}
            {service.icon === "code" && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke={service.iconColor} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="16 18 22 12 16 6" />
                <polyline points="8 6 2 12 8 18" />
                <line x1="14.5" y1="4" x2="9.5" y2="20" />
              </svg>
            )}
            {service.icon === "rocket" && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke={service.iconColor} stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
                <path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
                <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
                <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
              </svg>
            )}
          </div>

          <!-- Title -->
          <h3 class="mb-3 text-lg font-semibold text-white">
            {service.title}
          </h3>

          <!-- Description -->
          <p class="mb-6 text-sm leading-relaxed text-zinc-400">
            {service.description}
          </p>

          <!-- Link -->
          <a
            href={service.link}
            class="inline-flex items-center text-sm font-medium text-zinc-400 transition-colors duration-300 group-hover:text-white"
          >
            Learn more
            <svg class="ml-1.5 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10Z" clip-rule="evenodd" />
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section background ── */
  .services-section {
    background-color: #0f0f11;
  }

  /* ── Gradient text for "Build" ── */
  .services-gradient-text {
    background: linear-gradient(135deg, #6366f1, #06b6d4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Card base styles ── */
  .service-card {
    background-color: #18181b;
    border-color: rgba(255, 255, 255, 0.06);
  }

  /* ── Card hover glow ── */
  .service-card:hover {
    border-color: rgba(255, 255, 255, 0.15);
    box-shadow: 0 0 40px var(--glow-color), 0 0 80px var(--glow-color);
  }
</style>
