---
import AnimateOnScroll from '../shared/AnimateOnScroll.astro';

interface Service {
  title: string;
  description: string;
  link: string;
}

const services: Service[] = [
  {
    title: "AI Engineering",
    description:
      "We design and build AI systems — from LLM-powered agents to computer vision pipelines. Production-grade, not prototypes.",
    link: "/services/ai",
  },
  {
    title: "Technical Strategy",
    description:
      "Architecture reviews, infrastructure planning, and technology decisions that save months of engineering time.",
    link: "/services/consulting",
  },
  {
    title: "Software Engineering",
    description:
      "Full-stack development for web platforms, APIs, and automation systems. We write code that ships.",
    link: "/services/engineering",
  },
  {
    title: "DevOps & Infrastructure",
    description:
      "CI/CD pipelines, cloud architecture, monitoring, and deployment systems built for reliability.",
    link: "/services/development",
  },
];
---

<section id="services" class="py-32 lg:py-40" style="background-color: #000;">
  <div class="mx-auto max-w-5xl px-6">
    <!-- Section heading -->
    <AnimateOnScroll animation="fade-up">
      <div>
        <h2 class="text-4xl font-semibold tracking-tight text-white lg:text-5xl">
          Services
        </h2>
        <p class="mt-4 text-lg" style="color: #ababab;">
          What we do.
        </p>
      </div>
    </AnimateOnScroll>

    <!-- Services grid -->
    <AnimateOnScroll animation="stagger" class="mt-20 grid grid-cols-1 gap-8 md:grid-cols-2">
      {services.map((service) => (
        <div class="border-t pt-8" style="border-color: rgba(255, 255, 255, 0.1);">
          <h3 class="text-xl font-medium text-white">
            {service.title}
          </h3>
          <p class="mt-3 leading-relaxed" style="color: #ababab;">
            {service.description}
          </p>
          <a
            href={service.link}
            class="mt-4 inline-block text-sm transition-colors duration-200 hover:text-white"
            style="color: #666;"
          >
            Learn more &rarr;
          </a>
        </div>
      ))}
    </AnimateOnScroll>
  </div>
</section>
