---
import AnimateOnScroll from '../shared/AnimateOnScroll.astro';
---

<section class="py-16 lg:py-20">
  <div class="mx-auto max-w-5xl px-6">
    <AnimateOnScroll animation="fade-in">
      <div class="flex flex-col items-center gap-8 sm:flex-row sm:justify-center sm:gap-0 sm:divide-x sm:divide-white/10">
        <div class="px-8 text-center">
          <p class="text-sm uppercase tracking-wider text-text-muted">10+ ventures built</p>
        </div>
        <div class="px-8 text-center">
          <p class="text-sm uppercase tracking-wider text-text-muted">Production systems serving thousands</p>
        </div>
        <div class="px-8 text-center">
          <p class="text-sm uppercase tracking-wider text-text-muted">24hr response time</p>
        </div>
      </div>
      <p class="mt-10 text-center text-sm text-text-muted">
        Built systems for e-commerce, healthcare, fintech, logistics, and education.
      </p>
    </AnimateOnScroll>
  </div>
</section>
