---
interface Item {
  number: string;
  title: string;
  description: string;
}

const items: Item[] = [
  {
    number: "01",
    title: "Founder-led",
    description:
      "Every project is led personally by Connor O'Dea. No hand-offs, no junior developers, no account managers.",
  },
  {
    number: "02",
    title: "End-to-end",
    description:
      "From architecture to deployment. We don't just consult — we write the code, build the infrastructure, and ship to production.",
  },
  {
    number: "03",
    title: "Proven",
    description:
      "Ten ventures built from scratch. Systems handling real users, real data, and real revenue.",
  },
];
---

<section class="bg-black py-32 lg:py-40">
  <div class="mx-auto max-w-5xl px-6">
    <h2 class="text-4xl font-semibold tracking-tight text-white lg:text-5xl">
      Approach
    </h2>

    <div class="mt-16 grid grid-cols-1 gap-12 sm:gap-16 lg:grid-cols-3">
      {items.map((item) => (
        <div>
          <span class="font-mono text-sm text-text-muted">{item.number}</span>
          <h3 class="mt-4 text-xl font-medium text-white">{item.title}</h3>
          <p class="mt-3 leading-relaxed text-text-secondary">
            {item.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
