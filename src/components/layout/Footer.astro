---
const links = [
  { label: "Services", href: "/#services" },
  { label: "Work", href: "/#work" },
  { label: "About", href: "/#about" },
  { label: "Contact", href: "/#contact" },
  { label: "GitHub", href: "https://github.com/connorodea", external: true },
];
---

<footer class="border-t border-border">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 py-6 sm:flex-row">
    <p class="text-sm text-text-muted">
      &copy; 2026 Odea Works
    </p>
    <nav class="flex flex-wrap items-center gap-6">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="text-sm text-text-muted transition-colors duration-200 hover:text-text-secondary"
            {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
