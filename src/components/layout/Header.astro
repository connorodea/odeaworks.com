---
const navLinks = [
  { label: "Services", href: "/#services" },
  { label: "Pricing", href: "/pricing" },
  { label: "Work", href: "/#work" },
  { label: "Blog", href: "/blog" },
  { label: "About", href: "/#about" },
  { label: "Contact", href: "/#contact" },
];
---

<header
  id="site-header"
  class="fixed top-4 left-0 right-0 z-50 flex justify-center px-4"
>
  <nav
    id="header-nav"
    class="flex items-center gap-1 rounded-full border border-white/[0.08] bg-black/60 backdrop-blur-2xl px-3 py-1.5"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center px-2">
      <img src="/logos/ODeaWorks-v4-white-cropped.png" alt="ODeaWorks" class="h-5 w-auto" />
    </a>

    <!-- Separator -->
    <div class="hidden md:block w-px h-4 bg-white/10 mx-1"></div>

    <!-- Desktop nav links -->
    <div class="hidden items-center md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-full px-3 py-1.5 text-[13px] text-white/50 transition-colors duration-200 hover:text-white hover:bg-white/[0.06]"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/book"
        class="ml-1 rounded-full bg-white px-4 py-1.5 text-[13px] font-medium text-black transition-opacity duration-200 hover:opacity-90"
      >
        Book a Call
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="inline-flex items-center justify-center rounded-full p-2 text-white/50 transition-colors hover:text-white md:hidden"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <svg id="hamburger-icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
      <svg id="close-icon" class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>
</header>

<!-- Mobile menu -->
<div
  id="mobile-menu"
  class="fixed top-16 left-4 right-4 z-40 hidden md:hidden rounded-2xl border border-white/[0.08] bg-black/90 backdrop-blur-2xl"
>
  <div class="px-5 py-3 space-y-0.5">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          class="block rounded-lg py-2.5 px-3 text-[14px] text-white/50 transition-colors hover:text-white hover:bg-white/[0.06]"
        >
          {link.label}
        </a>
      ))
    }
    <a
      href="/book"
      class="mt-2 block rounded-full bg-white px-4 py-2.5 text-center text-[14px] font-medium text-black"
    >
      Book a Call
    </a>
  </div>
</div>

<!-- Spacer -->
<div class="h-16"></div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");
  const headerNav = document.getElementById("header-nav");

  // Mobile menu toggle
  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    hamburgerIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
    btn.setAttribute("aria-expanded", String(isOpen));
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    });
  });

  // Simple, clean scroll behavior — just opacity shift, no morphing
  const updateHeader = () => {
    if (!headerNav) return;
    if (window.scrollY > 20) {
      headerNav.style.backgroundColor = "rgba(0, 0, 0, 0.8)";
      headerNav.style.borderColor = "rgba(255, 255, 255, 0.1)";
    } else {
      headerNav.style.backgroundColor = "rgba(0, 0, 0, 0.6)";
      headerNav.style.borderColor = "rgba(255, 255, 255, 0.08)";
    }
  };

  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });
</script>
