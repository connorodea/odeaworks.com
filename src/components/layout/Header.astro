---
const navLinks = [
  { label: "Services", href: "/#services" },
  { label: "Pricing", href: "/pricing" },
  { label: "Work", href: "/#work" },
  { label: "Blog", href: "/blog" },
  { label: "About", href: "/#about" },
  { label: "Contact", href: "/#contact" },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-[border-color,background-color] duration-300 bg-background/80 backdrop-blur-xl border-b border-transparent"
>
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 h-16">
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img src="/logos/ODeaWorks-official.png" alt="ODeaWorks" class="h-8 w-auto" />
    </a>

    <!-- Desktop nav -->
    <div class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-[13px] text-text-secondary transition-colors duration-200 hover:text-text-primary"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/start"
        class="ml-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-medium text-white transition-colors duration-200 hover:bg-white/15"
      >
        Start a Project
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-btn"
      type="button"
      class="inline-flex items-center justify-center p-2 text-text-secondary transition-colors hover:text-text-primary md:hidden"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
    >
      <!-- Hamburger icon -->
      <svg
        id="hamburger-icon"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
      </svg>
      <!-- Close icon -->
      <svg
        id="close-icon"
        class="hidden h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-background/95 backdrop-blur-xl"
  >
    <div class="px-6 py-6 space-y-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="block py-3 text-[15px] text-text-secondary transition-colors hover:text-text-primary"
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/start"
        class="mt-4 block rounded-full bg-white/10 px-4 py-2.5 text-center text-[15px] font-medium text-white transition-colors hover:bg-white/15"
      >
        Start a Project
      </a>
    </div>
  </div>
</header>

<!-- Spacer to offset fixed header -->
<div class="h-16"></div>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const hamburgerIcon = document.getElementById("hamburger-icon");
  const closeIcon = document.getElementById("close-icon");
  const header = document.getElementById("site-header");

  // Toggle mobile menu
  btn?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    hamburgerIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
    btn.setAttribute("aria-expanded", String(isOpen));
  });

  // Close mobile menu on link click
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.add("hidden");
      hamburgerIcon?.classList.remove("hidden");
      closeIcon?.classList.add("hidden");
      btn?.setAttribute("aria-expanded", "false");
    });
  });

  // Add border on scroll
  const updateHeader = () => {
    if (!header) return;
    if (window.scrollY > 10) {
      header.classList.remove("border-transparent");
      header.classList.add("border-border");
    } else {
      header.classList.remove("border-border");
      header.classList.add("border-transparent");
    }
  };

  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });
</script>
