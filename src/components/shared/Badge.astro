---
interface Props {
  text: string;
  class?: string;
}

const { text, class: className = "" } = Astro.props;
---

<span
  class:list={[
    "inline-flex items-center rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-text-secondary transition-colors hover:border-border-hover hover:text-text-primary",
    className,
  ]}
>
  {text}
</span>
