---
interface Props {
  href?: string;
  variant?: "primary" | "secondary";
  size?: "sm" | "md" | "lg";
  class?: string;
  type?: "button" | "submit" | "reset";
}

const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
  type = "button",
  ...rest
} = Astro.props;

const baseStyles =
  "inline-flex items-center justify-center font-medium rounded-full transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-white/20 focus:ring-offset-2 focus:ring-offset-background";

const variants: Record<string, string> = {
  primary: "bg-white text-black hover:bg-white/90",
  secondary: "border border-white/20 text-white hover:bg-white/5",
};

const sizes: Record<string, string> = {
  sm: "px-5 py-2 text-sm gap-1.5",
  md: "px-6 py-2.5 text-sm gap-2",
  lg: "px-8 py-3 text-base gap-2.5",
};

const classes = [baseStyles, variants[variant], sizes[size], className]
  .filter(Boolean)
  .join(" ");
---

{
  href ? (
    <a href={href} class={classes} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes} {...rest}>
      <slot />
    </button>
  )
}
