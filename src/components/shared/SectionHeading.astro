---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  class?: string;
}

const {
  title,
  subtitle,
  align = "center",
  class: className = "",
} = Astro.props;

const alignClasses = align === "center" ? "text-center" : "text-left";
---

<div class:list={[alignClasses, className]}>
  <h2 class="text-3xl font-semibold tracking-tight text-text-primary sm:text-4xl lg:text-5xl">
    {title}
  </h2>
  {
    subtitle && (
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-text-secondary">
        {subtitle}
      </p>
    )
  }
</div>
