---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import FloatingCTA from "../components/shared/FloatingCTA.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "Odea Works — Software development and digital solutions.",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Odea Works",
  "url": "https://odeaworks.com",
  "logo": "https://odeaworks.com/favicon.svg",
  "description": "AI consulting, software engineering, and technical strategy.",
  "founder": {
    "@type": "Person",
    "name": "Connor O'Dea",
    "email": "connor@odeaworks.com",
    "url": "https://github.com/connorodea"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "connor@odeaworks.com",
    "contactType": "sales"
  },
  "sameAs": [
    "https://github.com/connorodea"
  ]
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

    <!-- Google Search Console Verification -->
    <meta name="google-site-verification" content="oHz1v3nmBKVm6nMFAhyENSNGviD19LGTizhgkZOaFhU" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Analytics (Umami — self-hosted, privacy-friendly, no cookies) -->
    <script defer src="https://analytics.odeaworks.com/script.js" data-website-id="f38ad26d-88a9-4eff-95f6-b59c8af82078"></script>

    <!-- Google Analytics 4 -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-WD93M6M8ZS"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-WD93M6M8ZS');
    </script>

    <!-- Preload Inter fonts -->
    <link
      rel="preload"
      href="/fonts/inter-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-latin-500-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-latin-600-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body class="bg-background text-text-primary font-sans antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <FloatingCTA />
    <Footer />
  </body>
</html>
