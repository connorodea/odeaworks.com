---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found | Odea Works" description="The page you're looking for doesn't exist.">

  <section class="flex min-h-screen items-center justify-center">
    <div class="text-center">
      <p class="text-8xl font-semibold text-white">404</p>
      <p class="mt-4 text-text-secondary">This page doesn't exist.</p>
      <nav class="mt-8 flex flex-wrap items-center justify-center gap-6 text-sm">
        <a href="/" class="text-text-muted transition-colors hover:text-white">Home</a>
        <a href="/blog" class="text-text-muted transition-colors hover:text-white">Blog</a>
        <a href="/work" class="text-text-muted transition-colors hover:text-white">Work</a>
        <a href="/contact" class="text-text-muted transition-colors hover:text-white">Contact</a>
      </nav>
    </div>
  </section>

</BaseLayout>
