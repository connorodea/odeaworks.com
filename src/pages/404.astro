---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found | Odea Works" description="The page you're looking for doesn't exist.">

  <section class="flex min-h-screen items-center justify-center">
    <div class="text-center">
      <p class="text-8xl font-semibold text-white">404</p>
      <p class="mt-4 text-text-secondary">This page doesn't exist.</p>
      <a
        href="/"
        class="mt-8 inline-block text-sm text-text-muted underline transition-colors hover:text-white"
      >
        Back to home
      </a>
    </div>
  </section>

</BaseLayout>
