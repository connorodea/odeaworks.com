---
import LandingLayout from '../layouts/LandingLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "AI Consulting Services",
  "provider": {
    "@type": "Organization",
    "name": "Odea Works",
    "url": "https://odeaworks.com"
  },
  "description": "Production AI systems — LLM agents, computer vision, RAG pipelines, and AI video automation. Built by engineers, not consultants.",
  "areaServed": "US",
  "serviceType": "AI Consulting"
};
---

<LandingLayout
  title="AI Consulting Services | Odea Works"
  description="Production AI systems — LLM agents, computer vision, RAG pipelines, and AI video automation. Built by engineers who've done it 10+ times."
  pageName="ai-consulting"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- HERO — Above the Fold -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden">
    <!-- Subtle gradient background -->
    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] to-transparent pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-accent/[0.03] rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative mx-auto max-w-6xl px-6 pt-16 pb-24 lg:pt-24 lg:pb-32">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-start">

        <!-- Left: Copy -->
        <div class="max-w-xl">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-4 py-1.5 mb-8">
            <div class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></div>
            <span class="text-xs font-medium tracking-wide text-text-secondary uppercase">AI Consulting</span>
          </div>

          <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-[3.5rem] lg:leading-[1.08]">
            AI Consulting That Ships Production Systems
          </h1>

          <p class="mt-6 text-lg leading-relaxed text-text-secondary lg:text-xl">
            Not slide decks. Not roadmaps. Working AI systems built by engineers who've done it 10+ times.
          </p>

          <!-- Trust signals -->
          <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-text-muted">
            <span class="flex items-center gap-2">
              <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              10+ ventures built
            </span>
            <span class="flex items-center gap-2">
              <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              Production AI systems
            </span>
            <span class="flex items-center gap-2">
              <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              24hr response
            </span>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="rounded-2xl border border-white/[0.08] bg-surface-2/50 backdrop-blur-sm p-8 lg:p-10">
          <p class="text-lg font-semibold text-white mb-1">Get a Free Assessment</p>
          <p class="text-sm text-text-muted mb-6">Tell us about your AI challenge. We'll respond within 24 hours.</p>
          <p class="text-xs text-text-muted mb-4">Or <a href="/book" class="text-accent hover:text-white transition-colors">book a discovery call</a> directly.</p>

          <form id="landing-form" method="POST" class="space-y-4">
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="source" value="landing-ai-consulting" />

            <div>
              <input
                type="text"
                name="name"
                required
                placeholder="Name"
                class="w-full rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20 focus:bg-surface-3"
              />
            </div>
            <div>
              <input
                type="email"
                name="email"
                required
                placeholder="Email"
                class="w-full rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20 focus:bg-surface-3"
              />
            </div>
            <div>
              <input
                type="text"
                name="company"
                placeholder="Company"
                class="w-full rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20 focus:bg-surface-3"
              />
            </div>
            <div>
              <textarea
                name="message"
                required
                rows="3"
                placeholder="What's your AI challenge?"
                class="w-full resize-none rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20 focus:bg-surface-3"
              ></textarea>
            </div>
            <button
              id="submit-btn"
              type="submit"
              class="w-full rounded-full bg-white px-8 py-3.5 text-sm font-semibold text-black transition-all duration-200 hover:opacity-90 hover:scale-[1.01] active:scale-[0.99] disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Get a Free Assessment &rarr;
            </button>
          </form>

          <!-- Success -->
          <div id="form-success" class="hidden py-8 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10">
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            </div>
            <p class="text-lg font-semibold text-white">Thank you!</p>
            <p class="mt-2 text-sm text-text-secondary">We'll review your challenge and respond within 24 hours.</p>
          </div>

          <!-- Error -->
          <div id="form-error" class="hidden mt-4 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3">
            <p class="text-sm text-red-400" id="form-error-text">Something went wrong. Please try again.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- WHAT WE BUILD -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="border-t border-border py-24 lg:py-32">
    <div class="mx-auto max-w-6xl px-6">
      <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Capabilities</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">What We Build</h2>

      <div class="mt-16 grid gap-8 sm:grid-cols-2">
        <!-- LLM Agent Systems -->
        <div class="group rounded-2xl border border-white/[0.06] bg-surface/50 p-8 transition-colors hover:border-white/[0.12]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
          </div>
          <h3 class="text-lg font-semibold text-white">LLM Agent Systems</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Autonomous AI agents that reason, plan, and execute complex tasks. Built with production-grade orchestration, memory, and tool integration.
          </p>
          <p class="mt-3 text-xs text-text-muted">See: ClawdHub</p>
        </div>

        <!-- Computer Vision -->
        <div class="group rounded-2xl border border-white/[0.06] bg-surface/50 p-8 transition-colors hover:border-white/[0.12]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-lg font-semibold text-white">Computer Vision Pipelines</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Image recognition, object detection, and visual inspection systems deployed at scale. From training data to production inference.
          </p>
          <p class="mt-3 text-xs text-text-muted">See: QuickVisionz</p>
        </div>

        <!-- AI Video Automation -->
        <div class="group rounded-2xl border border-white/[0.06] bg-surface/50 p-8 transition-colors hover:border-white/[0.12]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 011.28.53v11.38a.75.75 0 01-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 002.25-2.25v-9a2.25 2.25 0 00-2.25-2.25h-9A2.25 2.25 0 002.25 7.5v9a2.25 2.25 0 002.25 2.25z" /></svg>
          </div>
          <h3 class="text-lg font-semibold text-white">AI Video Automation</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Automated video generation, editing, and processing pipelines. AI-driven content creation at scale with custom models and workflows.
          </p>
          <p class="mt-3 text-xs text-text-muted">See: Vidmation</p>
        </div>

        <!-- RAG & Knowledge Systems -->
        <div class="group rounded-2xl border border-white/[0.06] bg-surface/50 p-8 transition-colors hover:border-white/[0.12]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>
          </div>
          <h3 class="text-lg font-semibold text-white">RAG & Knowledge Systems</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Retrieval-augmented generation pipelines that ground LLMs in your data. Vector search, embedding pipelines, and intelligent retrieval.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- HOW WE WORK -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="border-t border-border py-24 lg:py-32">
    <div class="mx-auto max-w-6xl px-6">
      <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Process</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">How We Work</h2>

      <div class="mt-16 grid gap-8 sm:grid-cols-3">
        <div class="relative">
          <div class="mb-4 text-5xl font-bold text-white/[0.06]">01</div>
          <h3 class="text-lg font-semibold text-white">Discover</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            We learn your business, your data, and your goals. We map out what's possible and what's practical with AI today.
          </p>
        </div>
        <div class="relative">
          <div class="mb-4 text-5xl font-bold text-white/[0.06]">02</div>
          <h3 class="text-lg font-semibold text-white">Build</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Rapid prototyping followed by production engineering. We ship working systems in weeks, not quarters.
          </p>
        </div>
        <div class="relative">
          <div class="mb-4 text-5xl font-bold text-white/[0.06]">03</div>
          <h3 class="text-lg font-semibold text-white">Deploy</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Production deployment with monitoring, observability, and iteration. We stay involved until the system is delivering value.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- RECENT WORK -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="border-t border-border py-24 lg:py-32">
    <div class="mx-auto max-w-6xl px-6">
      <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Portfolio</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Recent Work</h2>

      <div class="mt-16 grid gap-6 sm:grid-cols-3">
        <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
          <h3 class="text-base font-semibold text-white">ClawdHub</h3>
          <p class="mt-2 text-sm text-text-secondary">Multi-agent AI platform for autonomous task execution and complex reasoning workflows.</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">LLM Agents</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">Python</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">TypeScript</span>
          </div>
        </div>
        <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
          <h3 class="text-base font-semibold text-white">QuickVisionz</h3>
          <p class="mt-2 text-sm text-text-secondary">Computer vision system for automated product identification and quality inspection at scale.</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">Computer Vision</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">Python</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">TensorFlow</span>
          </div>
        </div>
        <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
          <h3 class="text-base font-semibold text-white">Vidmation</h3>
          <p class="mt-2 text-sm text-text-secondary">AI-powered video automation platform for generating, editing, and publishing content at scale.</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">AI Video</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">FFmpeg</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">Node.js</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- FINAL CTA -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="border-t border-border py-24 lg:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
        Ready to build?
      </h2>
      <p class="mt-4 text-lg text-text-secondary">
        Get your free AI assessment. We'll analyze your challenge and outline a path to production.
      </p>

      <div class="mt-12 mx-auto max-w-md">
        <div class="rounded-2xl border border-white/[0.08] bg-surface-2/50 p-8">
          <form id="landing-form-bottom" method="POST" class="space-y-4">
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="source" value="landing-ai-consulting" />

            <input
              type="text"
              name="name"
              required
              placeholder="Name"
              class="w-full rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20"
            />
            <input
              type="email"
              name="email"
              required
              placeholder="Email"
              class="w-full rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20"
            />
            <textarea
              name="message"
              required
              rows="3"
              placeholder="What's your AI challenge?"
              class="w-full resize-none rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20"
            ></textarea>
            <button
              id="submit-btn-bottom"
              type="submit"
              class="w-full rounded-full bg-white px-8 py-3.5 text-sm font-semibold text-black transition-all duration-200 hover:opacity-90 hover:scale-[1.01] active:scale-[0.99] disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Get a Free Assessment &rarr;
            </button>
          </form>

          <div id="form-success-bottom" class="hidden py-8 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10">
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            </div>
            <p class="text-lg font-semibold text-white">Thank you!</p>
            <p class="mt-2 text-sm text-text-secondary">We'll be in touch within 24 hours.</p>
          </div>

          <div id="form-error-bottom" class="hidden mt-4 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3">
            <p class="text-sm text-red-400" id="form-error-text-bottom">Something went wrong. Please try again.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    function initLandingForm(formId, submitBtnId, successId, errorId, errorTextId, source) {
      const form = document.getElementById(formId);
      const submitBtn = document.getElementById(submitBtnId);
      const successDiv = document.getElementById(successId);
      const errorDiv = document.getElementById(errorId);
      const errorText = document.getElementById(errorTextId);

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorDiv?.classList.add('hidden');

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending...';
        }

        const formData = new FormData(form);
        const data = {
          _honey: formData.get('_honey') || '',
          name: formData.get('name') || '',
          email: formData.get('email') || '',
          company: formData.get('company') || '',
          message: formData.get('message') || '',
          source: formData.get('source') || source,
        };

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          const result = await res.json();

          if (res.ok && result.success) {
            if (window.plausible) plausible('Lead Captured', {props: {source: source}});
            form.classList.add('hidden');
            successDiv?.classList.remove('hidden');
          } else {
            if (errorText) errorText.textContent = result.error || 'Something went wrong. Please try again.';
            errorDiv?.classList.remove('hidden');
          }
        } catch {
          if (errorText) errorText.textContent = 'Network error. Please check your connection and try again.';
          errorDiv?.classList.remove('hidden');
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Get a Free Assessment \u2192';
          }
        }
      });
    }

    initLandingForm('landing-form', 'submit-btn', 'form-success', 'form-error', 'form-error-text', 'landing-ai-consulting');
    initLandingForm('landing-form-bottom', 'submit-btn-bottom', 'form-success-bottom', 'form-error-bottom', 'form-error-text-bottom', 'landing-ai-consulting');
  </script>
</LandingLayout>
