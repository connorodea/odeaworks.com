---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AnimateOnScroll from '../../components/shared/AnimateOnScroll.astro';
import LeadCapture from '../../components/shared/LeadCapture.astro';
import { cities } from '../../data/city-seo';
import { aiAutomationTopics } from '../../data/topic-clusters';

const title = 'AI Consulting Services | Odea Works';
const description = 'Production AI consulting — LLM agents, computer vision, RAG pipelines, and custom ML models. Built by engineers who have shipped 10+ production AI systems. Serving 50+ US cities.';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "AI Consulting Services",
  "provider": {
    "@type": "Organization",
    "name": "Odea Works",
    "url": "https://odeaworks.com"
  },
  "description": description,
  "areaServed": "US",
  "serviceType": "AI Consulting",
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://odeaworks.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "AI Consulting",
      "item": "https://odeaworks.com/ai-consulting"
    }
  ]
};

// Separate remote from physical cities
const physicalCities = cities.filter((c) => c.slug !== 'remote');
const remoteListing = cities.find((c) => c.slug === 'remote');

// Case studies
const caseStudies = [
  {
    name: 'MedScribd',
    category: 'Healthcare AI',
    description: 'AI-powered clinical documentation platform that automates physician note generation from patient conversations. Reduced documentation time by 60% while maintaining medical coding compliance.',
    metrics: '60% time savings',
  },
  {
    name: 'QuickVisionz',
    category: 'Computer Vision',
    description: 'Custom YOLO-based computer vision pipeline for real-time product identification, classification, and sorting in warehouse operations. Processes thousands of items per hour.',
    metrics: '40% labor reduction',
  },
  {
    name: 'QuickLotz WMS',
    category: 'Enterprise AI',
    description: 'Enterprise warehouse management system with AI-driven product identification, automated grading, and real-time inventory optimization across multiple fulfillment channels.',
    metrics: '10,000+ SKUs managed',
  },
];
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Hero -->
  <section class="relative overflow-hidden py-32 lg:py-44">
    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] to-transparent pointer-events-none"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-accent/[0.03] rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <nav class="mb-8 flex items-center gap-2 text-sm text-text-muted">
          <a href="/" class="transition-colors hover:text-text-secondary">Home</a>
          <span>/</span>
          <span class="text-text-secondary">AI Consulting</span>
        </nav>

        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-4 py-1.5 mb-8">
          <div class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></div>
          <span class="text-xs font-medium tracking-wide text-text-secondary uppercase">AI Consulting Services</span>
        </div>

        <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-[3.5rem] lg:leading-[1.08]">
          AI Consulting Services
        </h1>
        <p class="mt-6 max-w-2xl text-xl text-text-secondary leading-relaxed">
          Production AI systems — not slide decks, not roadmaps, not proofs of concept that never ship. We design, build, and deploy AI that runs in production and delivers measurable business outcomes.
        </p>

        <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-text-muted">
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            10+ production AI systems shipped
          </span>
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            Founder-led engineering
          </span>
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            50+ cities served
          </span>
        </div>

        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/book"
            class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-medium text-black transition-opacity hover:opacity-90"
          >
            Book a free AI assessment
          </a>
          <a
            href="/work"
            class="inline-flex items-center justify-center rounded-full border border-white/20 px-8 py-3 text-sm font-medium text-white transition-colors hover:bg-white/5"
          >
            See our work
          </a>
        </div>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- What Is AI Consulting -->
  <section class="border-t border-white/10 py-24 lg:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Overview</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          What is AI consulting — and who needs it?
        </h2>
        <div class="mt-8 max-w-3xl space-y-6 text-lg text-text-secondary leading-relaxed">
          <p>
            AI consulting is the process of evaluating, designing, building, and deploying artificial intelligence systems for businesses. It covers everything from initial strategy and feasibility assessment to production deployment and ongoing optimization.
          </p>
          <p>
            You need AI consulting if you have a business process that involves pattern recognition, prediction, classification, generation, or automation at scale — and your current tools cannot keep up. The gap between "AI is possible" and "AI is deployed and delivering ROI" is an engineering gap, not a strategy gap.
          </p>
          <p>
            Odea Works bridges that gap. We are engineers who build AI systems, not consultants who write reports about them. Our founder has built and deployed 10+ production AI systems across healthcare, e-commerce, fintech, logistics, and more. When you work with us, you get working software — not a PowerPoint.
          </p>
        </div>
      </AnimateOnScroll>

      <AnimateOnScroll animation="stagger">
        <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
            <h3 class="text-lg font-semibold text-white">LLM Agents</h3>
            <p class="mt-2 text-sm text-text-secondary">Autonomous AI agents that handle complex multi-step workflows with tool use and decision-making.</p>
          </div>
          <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
            <h3 class="text-lg font-semibold text-white">Computer Vision</h3>
            <p class="mt-2 text-sm text-text-secondary">Image and video analysis for quality control, classification, detection, and visual automation.</p>
          </div>
          <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
            <h3 class="text-lg font-semibold text-white">RAG Pipelines</h3>
            <p class="mt-2 text-sm text-text-secondary">Knowledge retrieval systems that ground AI responses in your actual data with zero hallucination.</p>
          </div>
          <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
            <h3 class="text-lg font-semibold text-white">Custom ML</h3>
            <p class="mt-2 text-sm text-text-secondary">Prediction, classification, and optimization models trained on your data and deployed to production.</p>
          </div>
        </div>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- Case Studies -->
  <section class="border-t border-white/10 py-24 lg:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Case Studies</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Production AI systems we have built
        </h2>
        <p class="mt-6 max-w-2xl text-lg text-text-secondary leading-relaxed">
          These are not demos or prototypes. These are deployed systems handling real data, real users, and real business outcomes every day.
        </p>
      </AnimateOnScroll>

      <AnimateOnScroll animation="stagger">
        <div class="mt-16 grid gap-6 lg:grid-cols-3">
          {caseStudies.map((study) => (
            <div class="rounded-2xl border border-white/[0.08] bg-surface-2/50 p-8">
              <div class="flex items-center gap-3 mb-4">
                <div class="inline-flex items-center gap-2 rounded-full bg-accent/10 px-3 py-1">
                  <span class="text-xs font-medium text-accent">{study.category}</span>
                </div>
                <span class="text-xs text-text-muted">{study.metrics}</span>
              </div>
              <h3 class="text-lg font-semibold text-white mb-3">{study.name}</h3>
              <p class="text-sm text-text-secondary leading-relaxed">{study.description}</p>
            </div>
          ))}
        </div>
        <div class="mt-8">
          <a
            href="/work"
            class="inline-flex items-center gap-2 text-sm font-medium text-accent transition-colors hover:text-white"
          >
            See all our work
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- AI Automation Services (Topic Clusters) -->
  <section class="border-t border-white/10 py-24 lg:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <p class="text-sm uppercase tracking-widest text-text-muted mb-4">AI Automation</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          AI automation services
        </h2>
        <p class="mt-6 max-w-2xl text-lg text-text-secondary leading-relaxed">
          We automate specific business processes with purpose-built AI systems. Each service area represents a proven automation pattern we have deployed in production.
        </p>
      </AnimateOnScroll>

      <AnimateOnScroll animation="stagger">
        <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {aiAutomationTopics.map((topic) => (
            <a
              href={`/ai-automation/${topic.slug}`}
              class="group rounded-xl border border-white/[0.06] bg-surface/50 p-6 transition-colors hover:border-white/[0.12]"
            >
              <h3 class="text-sm font-medium text-white group-hover:text-accent transition-colors">{topic.name}</h3>
              <p class="mt-2 text-xs text-text-muted line-clamp-2">{topic.description}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {topic.useCase.split(', ').slice(0, 2).map((uc) => (
                  <span class="rounded-full border border-white/10 px-2 py-0.5 text-[10px] text-text-muted">{uc}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- AI Consulting by City -->
  <section class="border-t border-white/10 py-24 lg:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Locations</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          AI consulting by city
        </h2>
        <p class="mt-6 max-w-2xl text-lg text-text-secondary leading-relaxed">
          We serve businesses across the United States with production AI consulting. Each city page covers the local industries and AI use cases most relevant to that market.
        </p>
      </AnimateOnScroll>

      <AnimateOnScroll animation="stagger">
        <div class="mt-16 grid gap-3 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
          {physicalCities.map((city) => (
            <a
              href={`/ai-consulting/${city.slug}`}
              class="group rounded-lg border border-white/[0.06] bg-surface/50 px-4 py-3 transition-colors hover:border-white/[0.12]"
            >
              <p class="text-sm font-medium text-white group-hover:text-accent transition-colors">{city.name}, {city.state}</p>
              <p class="text-[11px] text-text-muted">{city.industries.join(', ')}</p>
            </a>
          ))}
        </div>
      </AnimateOnScroll>

      {remoteListing && (
        <AnimateOnScroll animation="fade-up" delay={200}>
          <div class="mt-8">
            <a
              href="/ai-consulting/remote"
              class="group flex items-center gap-3 rounded-xl border border-accent/20 bg-accent/5 px-6 py-4 transition-colors hover:border-accent/40"
            >
              <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
              <div>
                <p class="text-sm font-medium text-white group-hover:text-accent transition-colors">AI Consulting for Remote Teams</p>
                <p class="text-xs text-text-muted">Worldwide — SaaS, Tech, Startups</p>
              </div>
            </a>
          </div>
        </AnimateOnScroll>
      )}
    </div>
  </section>

  <!-- Pricing -->
  <section class="border-t border-white/10 py-24 lg:py-32">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Pricing</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          How AI consulting pricing works
        </h2>
        <div class="mt-8 max-w-3xl space-y-6 text-lg text-text-secondary leading-relaxed">
          <p>
            Every AI project is different, so we price based on scope and complexity — not billable hours. Most engagements start with a paid discovery phase to define the right solution before committing to full build.
          </p>
          <p>
            We offer project-based pricing, monthly retainers, and fractional CTO arrangements depending on your needs. The common thread: you always know what you are paying and what you are getting before work begins.
          </p>
        </div>
        <div class="mt-8">
          <a
            href="/pricing"
            class="inline-flex items-center gap-2 text-sm font-medium text-accent transition-colors hover:text-white"
          >
            View pricing details
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- Lead Capture -->
  <LeadCapture source="ai-consulting-pillar" />

  <!-- Footer Links -->
  <section class="border-t border-white/10 py-20">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <div class="flex flex-wrap gap-4 text-sm">
          <a href="/services" class="text-text-muted transition-colors hover:text-accent">All services</a>
          <span class="text-text-muted">/</span>
          <a href="/work" class="text-text-muted transition-colors hover:text-accent">Our work</a>
          <span class="text-text-muted">/</span>
          <a href="/blog" class="text-text-muted transition-colors hover:text-accent">Blog</a>
          <span class="text-text-muted">/</span>
          <a href="/pricing" class="text-text-muted transition-colors hover:text-accent">Pricing</a>
          <span class="text-text-muted">/</span>
          <a href="/about" class="text-text-muted transition-colors hover:text-accent">About</a>
          <span class="text-text-muted">/</span>
          <a href="/contact" class="text-text-muted transition-colors hover:text-accent">Contact</a>
          <span class="text-text-muted">/</span>
          <a href="/book" class="text-text-muted transition-colors hover:text-accent">Book a call</a>
        </div>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="border-t border-white/10 py-32 lg:py-40">
    <div class="mx-auto max-w-5xl px-6 text-center">
      <AnimateOnScroll animation="fade-up">
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
          Ready to build production AI?
        </h2>
        <p class="mt-4 text-lg text-text-secondary">
          Book a free AI assessment. We will analyze your use case and tell you honestly what is possible, what it will take, and whether AI is the right solution.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a
            href="/book"
            class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-medium text-black transition-opacity hover:opacity-90"
          >
            Book a free assessment
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full border border-white/20 px-8 py-3 text-sm font-medium text-white transition-colors hover:bg-white/5"
          >
            Get in touch
          </a>
        </div>
      </AnimateOnScroll>
    </div>
  </section>
</BaseLayout>
