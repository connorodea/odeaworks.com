---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimateOnScroll from '../components/shared/AnimateOnScroll.astro';

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Odea Works",
  "url": "https://odeaworks.com/contact",
  "mainEntity": {
    "@type": "Organization",
    "name": "Odea Works",
    "email": "connor@odeaworks.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Michigan",
      "addressCountry": "US"
    }
  }
};
---

<BaseLayout title="Contact | Odea Works" description="Get in touch with Odea Works. Tell us about your project and we'll get back to you within 24 hours.">
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} />

  <!-- Hero -->
  <section class="py-32 lg:py-40">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <h1 class="text-5xl font-semibold tracking-tight text-white lg:text-6xl">
          Contact
        </h1>
        <p class="mt-6 text-xl text-text-secondary">
          Tell us about your project.
        </p>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- Two-column layout -->
  <section class="pb-32 lg:pb-40">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="stagger" class="grid gap-16 lg:grid-cols-2">

        <!-- Left column: Info -->
        <div class="mt-0">
          <div>
            <p class="text-sm uppercase tracking-wider text-text-muted">Email</p>
            <a href="mailto:connor@odeaworks.com" class="mt-2 block text-lg text-white transition-colors hover:text-accent">
              connor@odeaworks.com
            </a>
          </div>

          <div class="mt-8">
            <p class="text-sm uppercase tracking-wider text-text-muted">Location</p>
            <p class="mt-2 text-text-secondary">Michigan, USA</p>
          </div>

          <div class="mt-8">
            <p class="text-sm uppercase tracking-wider text-text-muted">GitHub</p>
            <a
              href="https://github.com/connorodea"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-2 block text-text-secondary transition-colors hover:text-white"
            >
              github.com/connorodea
            </a>
          </div>

          <div class="mt-8">
            <p class="text-sm uppercase tracking-wider text-text-muted">Response time</p>
            <p class="mt-2 text-text-secondary">Usually within 24 hours.</p>
          </div>
        </div>

        <!-- Right column: Form -->
        <div class="mt-0">
          <form id="contact-form" method="POST" class="space-y-0">

            <!-- Honeypot -->
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

            <!-- Name -->
            <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Name"
                class="w-full bg-transparent py-4 text-white placeholder-text-muted outline-none"
              />
            </div>

            <!-- Email -->
            <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="Email"
                class="w-full bg-transparent py-4 text-white placeholder-text-muted outline-none"
              />
            </div>

            <!-- Company -->
            <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
              <input
                type="text"
                id="company"
                name="company"
                placeholder="Company"
                class="w-full bg-transparent py-4 text-white placeholder-text-muted outline-none"
              />
            </div>

            <!-- Budget -->
            <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
              <select
                id="budget"
                name="budget"
                class="w-full appearance-none bg-transparent py-4 text-text-muted outline-none [&:has(option:checked:not([value='']))]:text-white"
              >
                <option value="" disabled selected>Budget</option>
                <option value="under-10k">Under $10K</option>
                <option value="10k-25k">$10K - $25K</option>
                <option value="25k-50k">$25K - $50K</option>
                <option value="50k-100k">$50K - $100K</option>
                <option value="100k-plus">$100K+</option>
              </select>
            </div>

            <!-- Message -->
            <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
              <textarea
                id="message"
                name="message"
                required
                rows="4"
                placeholder="Message"
                class="w-full resize-none bg-transparent py-4 text-white placeholder-text-muted outline-none"
              ></textarea>
            </div>

            <!-- Submit -->
            <div class="pt-8">
              <button
                id="submit-btn"
                type="submit"
                class="rounded-full bg-white px-8 py-3 text-sm font-medium text-black transition-opacity hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
              >
                Send message
              </button>
            </div>
          </form>

          <!-- Success message (hidden by default) -->
          <div id="form-success" class="hidden py-12">
            <p class="text-lg font-medium text-white">Thank you!</p>
            <p class="mt-2 text-text-secondary">We'll be in touch within 24 hours.</p>
          </div>

          <!-- Error message (hidden by default) -->
          <div id="form-error" class="hidden mt-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3">
            <p class="text-sm text-red-400" id="form-error-text">Something went wrong. Please try again.</p>
          </div>
        </div>
      </AnimateOnScroll>
    </div>
  </section>

  <script>
    const form = document.getElementById('contact-form');
    const submitBtn = document.getElementById('submit-btn');
    const successDiv = document.getElementById('form-success');
    const errorDiv = document.getElementById('form-error');
    const errorText = document.getElementById('form-error-text');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Hide previous messages
      errorDiv?.classList.add('hidden');

      // Loading state
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';
      }

      // Collect form data
      const formData = new FormData(form);
      const data = {
        _honey: formData.get('_honey') || '',
        name: formData.get('name') || '',
        email: formData.get('email') || '',
        company: formData.get('company') || '',
        budget: formData.get('budget') || '',
        message: formData.get('message') || '',
      };

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (res.ok && result.success) {
          // Track conversion
          if (window.plausible) plausible('Contact Form Submitted');
          // Success — hide form, show thank-you
          form.classList.add('hidden');
          successDiv?.classList.remove('hidden');
        } else {
          // Server returned an error
          if (errorText) {
            errorText.textContent = result.error || 'Something went wrong. Please try again.';
          }
          errorDiv?.classList.remove('hidden');
        }
      } catch {
        // Network error
        if (errorText) {
          errorText.textContent = 'Network error. Please check your connection and try again.';
        }
        errorDiv?.classList.remove('hidden');
      } finally {
        // Reset button
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send message';
        }
      }
    });
  </script>

</BaseLayout>
