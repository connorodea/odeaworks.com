    <!-- Related -->
    <div class="mt-16 border-t border-white/10 pt-12">
      <h3 class="text-sm text-[#666] uppercase tracking-wider mb-6">Related resources</h3>
      <div class="space-y-4">
        <a href="/guides/hiring-ai-consultant" class="block text-white hover:text-[#10a37f] transition-colors">
          The Complete Guide to Hiring an AI Consultant in 2026 &rarr;
        </a>
        <a href="/blog/2026-04-05-how-to-evaluate-ai-vendors" class="block text-white hover:text-[#10a37f] transition-colors">
          How to Evaluate AI Vendors: A Technical Decision Framework &rarr;
        </a>
        <a href="/blog/2026-04-05-build-vs-buy-ai-capabilities" class="block text-white hover:text-[#10a37f] transition-colors">
