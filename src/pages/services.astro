---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  {
    title: 'AI Engineering',
    description:
      'We design, build, and deploy production AI systems. From autonomous agents to retrieval-augmented generation, we bring intelligent capabilities from prototype to production with rigorous evaluation at every stage.',
    offerings: [
      'Agent systems',
      'RAG architectures',
      'Computer vision',
      'ML pipelines',
      'Model evaluation',
      'Prompt engineering',
    ],
  },
  {
    title: 'Technical Strategy',
    description:
      'We help engineering teams make better decisions. Architecture reviews, technology selection, infrastructure audits, and scaling roadmaps — designed to reduce cost and increase velocity.',
    offerings: [
      'Architecture review',
      'Technology selection',
      'Infrastructure audit',
      'Scaling roadmap',
      'Cost optimization',
      'Technical due diligence',
    ],
  },
  {
    title: 'Software Engineering',
    description:
      'We build the software that businesses depend on. Full-stack web applications, APIs, databases, automation systems, and developer tools — shipped fast, built to last.',
    offerings: [
      'Web applications',
      'APIs & integrations',
      'Database design',
      'Automation systems',
      'CLI tools',
      'SaaS platforms',
    ],
  },
  {
    title: 'Infrastructure & DevOps',
    description:
      'We architect and maintain the infrastructure that keeps applications running. CI/CD pipelines, cloud deployments, monitoring, and security — engineered for reliability at scale.',
    offerings: [
      'CI/CD pipelines',
      'Cloud deployment',
      'Monitoring & observability',
      'Security hardening',
      'Container orchestration',
      'Cost management',
    ],
  },
];
---

<BaseLayout title="Services | Odea Works" description="AI engineering, technical strategy, software development, and infrastructure services from Odea Works.">

  <!-- Hero -->
  <section class="py-32 lg:py-40">
    <div class="mx-auto max-w-5xl px-6">
      <h1 class="text-5xl font-semibold tracking-tight text-white lg:text-6xl">
        Services
      </h1>
      <p class="mt-6 text-xl text-text-secondary">
        What we offer.
      </p>
    </div>
  </section>

  <!-- Service sections -->
  {services.map((service) => (
    <section class="border-t border-white/10 py-20">
      <div class="mx-auto max-w-5xl px-6">
        <h2 class="text-3xl font-semibold text-white">
          {service.title}
        </h2>
        <p class="mt-6 max-w-2xl text-lg text-text-secondary leading-relaxed">
          {service.description}
        </p>
        <div class="mt-8 grid grid-cols-2 gap-x-12 gap-y-3">
          {service.offerings.map((item) => (
            <p class="text-text-secondary">{item}</p>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Bottom CTA -->
  <section class="border-t border-white/10 py-32 lg:py-40">
    <div class="mx-auto max-w-5xl px-6 text-center">
      <h2 class="text-2xl font-semibold text-white">
        Ready to start?
      </h2>
      <div class="mt-8">
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-medium text-black transition-opacity hover:opacity-90"
        >
          Get in touch
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
