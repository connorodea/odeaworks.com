---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimateOnScroll from '../components/shared/AnimateOnScroll.astro';
import LeadCapture from '../components/shared/LeadCapture.astro';
import { industries, locations } from '../data/programmatic-seo';

const services = [
  {
    title: 'AI Engineering',
    slug: 'ai-consulting',
    description:
      'We design, build, and deploy production AI systems. From autonomous agents to retrieval-augmented generation, we bring intelligent capabilities from prototype to production with rigorous evaluation at every stage.',
    offerings: [
      'Agent systems',
      'RAG architectures',
      'Computer vision',
      'ML pipelines',
      'Model evaluation',
      'Prompt engineering',
    ],
  },
  {
    title: 'Technical Strategy',
    slug: 'technical-strategy',
    description:
      'We help engineering teams make better decisions. Architecture reviews, technology selection, infrastructure audits, and scaling roadmaps — designed to reduce cost and increase velocity.',
    offerings: [
      'Architecture review',
      'Technology selection',
      'Infrastructure audit',
      'Scaling roadmap',
      'Cost optimization',
      'Technical due diligence',
    ],
  },
  {
    title: 'Software Engineering',
    slug: 'software-development',
    description:
      'We build the software that businesses depend on. Full-stack web applications, APIs, databases, automation systems, and developer tools — shipped fast, built to last.',
    offerings: [
      'Web applications',
      'APIs & integrations',
      'Database design',
      'Automation systems',
      'CLI tools',
      'SaaS platforms',
    ],
  },
  {
    title: 'Infrastructure & DevOps',
    slug: null,
    description:
      'We architect and maintain the infrastructure that keeps applications running. CI/CD pipelines, cloud deployments, monitoring, and security — engineered for reliability at scale.',
    offerings: [
      'CI/CD pipelines',
      'Cloud deployment',
      'Monitoring & observability',
      'Security hardening',
      'Container orchestration',
      'Cost management',
    ],
  },
];

const servicesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": [
    {
      "@type": "Service",
      "name": "AI Engineering",
      "provider": {"@type": "Organization", "name": "Odea Works"},
      "description": "LLM agent systems, computer vision, RAG architectures, ML pipelines."
    },
    {
      "@type": "Service",
      "name": "Technical Strategy",
      "provider": {"@type": "Organization", "name": "Odea Works"},
      "description": "Architecture reviews, infrastructure planning, technology selection."
    },
    {
      "@type": "Service",
      "name": "Software Engineering",
      "provider": {"@type": "Organization", "name": "Odea Works"},
      "description": "Full-stack web applications, APIs, databases, automation systems."
    },
    {
      "@type": "Service",
      "name": "Infrastructure & DevOps",
      "provider": {"@type": "Organization", "name": "Odea Works"},
      "description": "CI/CD pipelines, cloud deployment, monitoring, container orchestration."
    }
  ]
};
---

<BaseLayout title="Services | Odea Works" description="AI engineering, technical strategy, software development, and infrastructure services from Odea Works.">
  <script type="application/ld+json" set:html={JSON.stringify(servicesSchema)} />

  <!-- Hero -->
  <section class="py-32 lg:py-40">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <h1 class="text-5xl font-semibold tracking-tight text-white lg:text-6xl">
          Services
        </h1>
        <p class="mt-6 text-xl text-text-secondary">
          What we offer.
        </p>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- Service sections -->
  {services.map((service) => (
    <section class="border-t border-white/10 py-20">
      <div class="mx-auto max-w-5xl px-6">
        <AnimateOnScroll animation="fade-up">
          <h2 class="text-3xl font-semibold text-white">
            {service.title}
          </h2>
          <p class="mt-6 max-w-2xl text-lg text-text-secondary leading-relaxed">
            {service.description}
          </p>
          <div class="mt-8 grid grid-cols-2 gap-x-12 gap-y-3">
            {service.offerings.map((item) => (
              <p class="text-text-secondary">{item}</p>
            ))}
          </div>

          {/* Industry links for services that have programmatic pages */}
          {service.slug && (
            <div class="mt-10">
              <p class="text-sm font-medium text-text-muted mb-3">See how we help:</p>
              <div class="flex flex-wrap gap-2">
                {industries.map((ind) => (
                  <a
                    href={`/services/${service.slug}-for-${ind.slug}`}
                    class="rounded-full border border-white/[0.08] px-3 py-1.5 text-xs text-text-secondary transition-colors hover:border-accent/30 hover:text-accent"
                  >
                    {ind.name}
                  </a>
                ))}
              </div>
              <div class="mt-3 flex flex-wrap gap-2">
                {locations.map((loc) => (
                  <a
                    href={`/services/${service.slug}-${loc.slug}`}
                    class="rounded-full border border-white/[0.08] px-3 py-1.5 text-xs text-text-secondary transition-colors hover:border-accent/30 hover:text-accent"
                  >
                    {loc.preposition === 'for' ? `${loc.name}` : loc.name}
                  </a>
                ))}
              </div>
            </div>
          )}
        </AnimateOnScroll>
      </div>
    </section>
  ))}

  <!-- Lead Capture -->
  <LeadCapture source="services" />

  <!-- Bottom CTA -->
  <section class="border-t border-white/10 py-32 lg:py-40">
    <div class="mx-auto max-w-5xl px-6 text-center">
      <AnimateOnScroll animation="fade-up">
        <h2 class="text-2xl font-semibold text-white">
          Ready to start?
        </h2>
        <div class="mt-8">
          <a
            href="/contact"
            class="inline-flex items-center justify-center rounded-full bg-white px-8 py-3 text-sm font-medium text-black transition-opacity hover:opacity-90"
          >
            Get in touch
          </a>
        </div>
      </AnimateOnScroll>
    </div>
  </section>

</BaseLayout>
