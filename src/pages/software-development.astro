---
import LandingLayout from '../layouts/LandingLayout.astro';

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Custom Software Development",
  "provider": {
    "@type": "Organization",
    "name": "Odea Works",
    "url": "https://odeaworks.com"
  },
  "description": "Full-stack custom software development — SaaS platforms, enterprise dashboards, APIs, and automation systems. No outsourcing, no handoffs.",
  "areaServed": "US",
  "serviceType": "Software Development"
};
---

<LandingLayout
  title="Custom Software Development | Odea Works"
  description="Full-stack engineering from architecture to production. SaaS platforms, enterprise dashboards, APIs, and automation systems. No outsourcing."
  pageName="software-development"
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- HERO — Above the Fold -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] to-transparent pointer-events-none"></div>
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-500/[0.02] rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative mx-auto max-w-6xl px-6 pt-16 pb-24 lg:pt-24 lg:pb-32">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16 items-start">

        <!-- Left: Copy -->
        <div class="max-w-xl">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/[0.03] px-4 py-1.5 mb-8">
            <div class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></div>
            <span class="text-xs font-medium tracking-wide text-text-secondary uppercase">Software Development</span>
          </div>

          <h1 class="text-4xl font-semibold tracking-tight text-white sm:text-5xl lg:text-[3.5rem] lg:leading-[1.08]">
            Custom Software. Built Right. Shipped Fast.
          </h1>

          <p class="mt-6 text-lg leading-relaxed text-text-secondary lg:text-xl">
            Full-stack engineering from architecture to production. No outsourcing, no handoffs.
          </p>

          <!-- Trust signals -->
          <div class="mt-8 flex flex-wrap gap-3 text-sm text-text-muted">
            <span class="rounded-full bg-white/[0.05] px-3 py-1">TypeScript</span>
            <span class="rounded-full bg-white/[0.05] px-3 py-1">React</span>
            <span class="rounded-full bg-white/[0.05] px-3 py-1">Python</span>
            <span class="rounded-full bg-white/[0.05] px-3 py-1">PostgreSQL</span>
            <span class="rounded-full bg-white/[0.05] px-3 py-1">50+ projects shipped</span>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="rounded-2xl border border-white/[0.08] bg-surface-2/50 backdrop-blur-sm p-8 lg:p-10">
          <p class="text-lg font-semibold text-white mb-1">Get a Free Estimate</p>
          <p class="text-sm text-text-muted mb-6">Tell us about your project. We'll respond within 24 hours with a plan.</p>
          <p class="text-xs text-text-muted mb-4">Or <a href="/book" class="text-accent hover:text-white transition-colors">book a discovery call</a> directly.</p>

          <form id="landing-form" method="POST" class="space-y-4">
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="source" value="landing-software-development" />

            <div>
              <input
                type="text"
                name="name"
                required
                placeholder="Name"
                class="w-full rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20 focus:bg-surface-3"
              />
            </div>
            <div>
              <input
                type="email"
                name="email"
                required
                placeholder="Email"
                class="w-full rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20 focus:bg-surface-3"
              />
            </div>
            <div>
              <textarea
                name="message"
                required
                rows="3"
                placeholder="Tell us about your project"
                class="w-full resize-none rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20"
              ></textarea>
            </div>
            <button
              id="submit-btn"
              type="submit"
              class="w-full rounded-full bg-white px-8 py-3.5 text-sm font-semibold text-black transition-all duration-200 hover:opacity-90 hover:scale-[1.01] active:scale-[0.99] disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Get a Free Estimate &rarr;
            </button>
          </form>

          <!-- Success -->
          <div id="form-success" class="hidden py-8 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10">
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            </div>
            <p class="text-lg font-semibold text-white">Thank you!</p>
            <p class="mt-2 text-sm text-text-secondary">We'll review your project and get back to you within 24 hours.</p>
          </div>

          <!-- Error -->
          <div id="form-error" class="hidden mt-4 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3">
            <p class="text-sm text-red-400" id="form-error-text">Something went wrong. Please try again.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- WHAT WE BUILD -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="border-t border-border py-24 lg:py-32">
    <div class="mx-auto max-w-6xl px-6">
      <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Capabilities</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">What We Build</h2>

      <div class="mt-16 grid gap-8 sm:grid-cols-2">
        <!-- SaaS Platforms -->
        <div class="group rounded-2xl border border-white/[0.06] bg-surface/50 p-8 transition-colors hover:border-white/[0.12]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" /></svg>
          </div>
          <h3 class="text-lg font-semibold text-white">SaaS Platforms</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Multi-tenant applications with authentication, billing, real-time features, and scalable architecture. From MVP to enterprise.
          </p>
        </div>

        <!-- Enterprise Dashboards -->
        <div class="group rounded-2xl border border-white/[0.06] bg-surface/50 p-8 transition-colors hover:border-white/[0.12]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" /></svg>
          </div>
          <h3 class="text-lg font-semibold text-white">Enterprise Dashboards</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Data visualization, reporting, and operational dashboards. Real-time data, complex filters, role-based access, and export capabilities.
          </p>
        </div>

        <!-- APIs & Integrations -->
        <div class="group rounded-2xl border border-white/[0.06] bg-surface/50 p-8 transition-colors hover:border-white/[0.12]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" /></svg>
          </div>
          <h3 class="text-lg font-semibold text-white">APIs & Integrations</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            RESTful and GraphQL APIs, third-party integrations, webhook systems, and data pipelines. Built for reliability and performance.
          </p>
        </div>

        <!-- Automation Systems -->
        <div class="group rounded-2xl border border-white/[0.06] bg-surface/50 p-8 transition-colors hover:border-white/[0.12]">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10">
            <svg class="h-5 w-5 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M2.985 19.644l3.181-3.182" /></svg>
          </div>
          <h3 class="text-lg font-semibold text-white">Automation Systems</h3>
          <p class="mt-2 text-sm leading-relaxed text-text-secondary">
            Workflow automation, scheduled jobs, event-driven architectures, and intelligent process orchestration. Reduce manual work by 10x.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- OUR STACK -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="border-t border-border py-24 lg:py-32">
    <div class="mx-auto max-w-6xl px-6">
      <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Technology</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Our Stack</h2>

      <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-4">Frontend</h3>
          <ul class="space-y-2.5 text-sm text-text-secondary">
            <li>React / Next.js</li>
            <li>TypeScript</li>
            <li>Tailwind CSS</li>
            <li>Astro</li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-4">Backend</h3>
          <ul class="space-y-2.5 text-sm text-text-secondary">
            <li>Node.js</li>
            <li>Python</li>
            <li>Express / Fastify</li>
            <li>REST & GraphQL</li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-4">Data</h3>
          <ul class="space-y-2.5 text-sm text-text-secondary">
            <li>PostgreSQL</li>
            <li>Redis</li>
            <li>MongoDB</li>
            <li>Vector databases</li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wider text-text-muted mb-4">Infrastructure</h3>
          <ul class="space-y-2.5 text-sm text-text-secondary">
            <li>Docker</li>
            <li>GitHub Actions CI/CD</li>
            <li>Hetzner / AWS</li>
            <li>Nginx / Caddy</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- RECENT WORK -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="border-t border-border py-24 lg:py-32">
    <div class="mx-auto max-w-6xl px-6">
      <p class="text-sm uppercase tracking-widest text-text-muted mb-4">Portfolio</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Recent Work</h2>

      <div class="mt-16 grid gap-6 sm:grid-cols-3">
        <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
          <h3 class="text-base font-semibold text-white">QuickLotz WMS</h3>
          <p class="mt-2 text-sm text-text-secondary">Full warehouse management system with real-time inventory tracking, order management, and automated workflows.</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">React</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">Node.js</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">PostgreSQL</span>
          </div>
        </div>
        <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
          <h3 class="text-base font-semibold text-white">Inquizit</h3>
          <p class="mt-2 text-sm text-text-secondary">AI-powered quiz and assessment platform with dynamic question generation, analytics, and adaptive learning paths.</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">TypeScript</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">Next.js</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">AI/ML</span>
          </div>
        </div>
        <div class="rounded-2xl border border-white/[0.06] bg-surface/50 p-6">
          <h3 class="text-base font-semibold text-white">MedScribd</h3>
          <p class="mt-2 text-sm text-text-secondary">Medical documentation platform with AI-assisted note generation, template management, and compliance features.</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">React</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">Python</span>
            <span class="rounded-full bg-white/[0.05] px-2.5 py-1 text-[11px] text-text-muted">Healthcare</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════ -->
  <!-- FINAL CTA -->
  <!-- ═══════════════════════════════════════════════════════ -->
  <section class="border-t border-border py-24 lg:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">
        Let's build something great.
      </h2>
      <p class="mt-4 text-lg text-text-secondary">
        Tell us about your project and get a free estimate within 24 hours.
      </p>

      <div class="mt-12 mx-auto max-w-md">
        <div class="rounded-2xl border border-white/[0.08] bg-surface-2/50 p-8">
          <form id="landing-form-bottom" method="POST" class="space-y-4">
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="source" value="landing-software-development" />

            <input
              type="text"
              name="name"
              required
              placeholder="Name"
              class="w-full rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20"
            />
            <input
              type="email"
              name="email"
              required
              placeholder="Email"
              class="w-full rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20"
            />
            <textarea
              name="message"
              required
              rows="3"
              placeholder="Tell us about your project"
              class="w-full resize-none rounded-lg border border-white/[0.08] bg-surface-3 px-4 py-3 text-sm text-white placeholder-text-muted outline-none transition-colors focus:border-white/20"
            ></textarea>
            <button
              id="submit-btn-bottom"
              type="submit"
              class="w-full rounded-full bg-white px-8 py-3.5 text-sm font-semibold text-black transition-all duration-200 hover:opacity-90 hover:scale-[1.01] active:scale-[0.99] disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Get a Free Estimate &rarr;
            </button>
          </form>

          <div id="form-success-bottom" class="hidden py-8 text-center">
            <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10">
              <svg class="h-6 w-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
            </div>
            <p class="text-lg font-semibold text-white">Thank you!</p>
            <p class="mt-2 text-sm text-text-secondary">We'll be in touch within 24 hours.</p>
          </div>

          <div id="form-error-bottom" class="hidden mt-4 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3">
            <p class="text-sm text-red-400" id="form-error-text-bottom">Something went wrong. Please try again.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    function initLandingForm(formId, submitBtnId, successId, errorId, errorTextId, source, buttonLabel) {
      const form = document.getElementById(formId);
      const submitBtn = document.getElementById(submitBtnId);
      const successDiv = document.getElementById(successId);
      const errorDiv = document.getElementById(errorId);
      const errorText = document.getElementById(errorTextId);

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorDiv?.classList.add('hidden');

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sending...';
        }

        const formData = new FormData(form);
        const data = {
          _honey: formData.get('_honey') || '',
          name: formData.get('name') || '',
          email: formData.get('email') || '',
          company: formData.get('company') || '',
          message: formData.get('message') || '',
          source: formData.get('source') || source,
        };

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          const result = await res.json();

          if (res.ok && result.success) {
            if (window.plausible) plausible('Lead Captured', {props: {source: source}});
            form.classList.add('hidden');
            successDiv?.classList.remove('hidden');
          } else {
            if (errorText) errorText.textContent = result.error || 'Something went wrong. Please try again.';
            errorDiv?.classList.remove('hidden');
          }
        } catch {
          if (errorText) errorText.textContent = 'Network error. Please check your connection and try again.';
          errorDiv?.classList.remove('hidden');
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = buttonLabel;
          }
        }
      });
    }

    initLandingForm('landing-form', 'submit-btn', 'form-success', 'form-error', 'form-error-text', 'landing-software-development', 'Get a Free Estimate \u2192');
    initLandingForm('landing-form-bottom', 'submit-btn-bottom', 'form-success-bottom', 'form-error-bottom', 'form-error-text-bottom', 'landing-software-development', 'Get a Free Estimate \u2192');
  </script>
</LandingLayout>
