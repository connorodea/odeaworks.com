---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimateOnScroll from '../components/shared/AnimateOnScroll.astro';

const startSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Start a Project | Odea Works",
  "url": "https://odeaworks.com/start",
  "description": "Tell us about your project. We build AI systems, web applications, and production infrastructure.",
  "mainEntity": {
    "@type": "Organization",
    "name": "Odea Works",
    "email": "connor@odeaworks.com"
  }
};
---

<BaseLayout title="Start a Project | Odea Works" description="Tell us about your project. AI systems, web applications, technical strategy, and infrastructure.">
  <script type="application/ld+json" set:html={JSON.stringify(startSchema)} />

  <!-- Hero -->
  <section class="py-32 lg:py-40">
    <div class="mx-auto max-w-3xl px-6">
      <AnimateOnScroll animation="fade-up">
        <h1 class="text-5xl font-semibold tracking-tight text-white lg:text-6xl">
          Start a project
        </h1>
        <p class="mt-6 text-xl text-text-secondary">
          Tell us about what you're building.
        </p>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- Form -->
  <section class="pb-32 lg:pb-40">
    <div class="mx-auto max-w-3xl px-6">
      <form id="start-form" method="POST">

        <!-- Honeypot -->
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <!-- Section 1: What do you need? -->
        <AnimateOnScroll animation="fade-up">
          <div class="mb-20">
            <p class="text-sm uppercase tracking-wider text-text-muted mb-8">What do you need?</p>
            <div class="grid gap-4 sm:grid-cols-2">
              <button
                type="button"
                class="project-type-card group rounded-xl border border-white/10 p-6 text-left transition-all duration-200 hover:border-white/20 hover:bg-white/[0.03]"
                data-value="ai-system"
              >
                <p class="text-[15px] font-medium text-white">AI System</p>
                <p class="mt-1.5 text-sm text-text-muted">LLM agents, computer vision, ML pipelines</p>
              </button>
              <button
                type="button"
                class="project-type-card group rounded-xl border border-white/10 p-6 text-left transition-all duration-200 hover:border-white/20 hover:bg-white/[0.03]"
                data-value="web-application"
              >
                <p class="text-[15px] font-medium text-white">Web Application</p>
                <p class="mt-1.5 text-sm text-text-muted">Full-stack platform, SaaS, dashboard</p>
              </button>
              <button
                type="button"
                class="project-type-card group rounded-xl border border-white/10 p-6 text-left transition-all duration-200 hover:border-white/20 hover:bg-white/[0.03]"
                data-value="technical-strategy"
              >
                <p class="text-[15px] font-medium text-white">Technical Strategy</p>
                <p class="mt-1.5 text-sm text-text-muted">Architecture review, technology planning</p>
              </button>
              <button
                type="button"
                class="project-type-card group rounded-xl border border-white/10 p-6 text-left transition-all duration-200 hover:border-white/20 hover:bg-white/[0.03]"
                data-value="infrastructure"
              >
                <p class="text-[15px] font-medium text-white">Infrastructure</p>
                <p class="mt-1.5 text-sm text-text-muted">CI/CD, deployment, monitoring, DevOps</p>
              </button>
            </div>
            <input type="hidden" id="project-type" name="projectType" value="" />
          </div>
        </AnimateOnScroll>

        <!-- Section 2: Project details -->
        <AnimateOnScroll animation="fade-up">
          <div class="mb-20">
            <p class="text-sm uppercase tracking-wider text-text-muted mb-8">Project details</p>
            <div class="space-y-0">
              <!-- Description -->
              <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
                <textarea
                  id="description"
                  name="description"
                  required
                  rows="4"
                  placeholder="Tell us about your project"
                  class="w-full resize-none bg-transparent py-4 text-white placeholder-text-muted outline-none"
                ></textarea>
              </div>

              <!-- Timeline -->
              <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
                <select
                  id="timeline"
                  name="timeline"
                  class="w-full appearance-none bg-transparent py-4 text-text-muted outline-none [&:has(option:checked:not([value='']))]:text-white"
                >
                  <option value="" disabled selected>Timeline</option>
                  <option value="asap">ASAP</option>
                  <option value="1-3-months">1-3 months</option>
                  <option value="3-6-months">3-6 months</option>
                  <option value="exploring">Just exploring</option>
                </select>
              </div>

              <!-- Budget -->
              <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
                <select
                  id="budget"
                  name="budget"
                  class="w-full appearance-none bg-transparent py-4 text-text-muted outline-none [&:has(option:checked:not([value='']))]:text-white"
                >
                  <option value="" disabled selected>Budget range</option>
                  <option value="under-10k">Under $10K</option>
                  <option value="10k-25k">$10K - $25K</option>
                  <option value="25k-50k">$25K - $50K</option>
                  <option value="50k-100k">$50K - $100K</option>
                  <option value="100k-plus">$100K+</option>
                </select>
              </div>
            </div>
          </div>
        </AnimateOnScroll>

        <!-- Section 3: Your info -->
        <AnimateOnScroll animation="fade-up">
          <div class="mb-12">
            <p class="text-sm uppercase tracking-wider text-text-muted mb-8">Your info</p>
            <div class="space-y-0">
              <!-- Name -->
              <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Name"
                  class="w-full bg-transparent py-4 text-white placeholder-text-muted outline-none"
                />
              </div>

              <!-- Email -->
              <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="Email"
                  class="w-full bg-transparent py-4 text-white placeholder-text-muted outline-none"
                />
              </div>

              <!-- Company -->
              <div class="border-b border-white/10 focus-within:border-white/30 transition-colors">
                <input
                  type="text"
                  id="company"
                  name="company"
                  placeholder="Company (optional)"
                  class="w-full bg-transparent py-4 text-white placeholder-text-muted outline-none"
                />
              </div>
            </div>
          </div>
        </AnimateOnScroll>

        <!-- Submit -->
        <AnimateOnScroll animation="fade-up">
          <div class="pt-4">
            <button
              id="submit-btn"
              type="submit"
              class="rounded-full bg-white px-8 py-3 text-sm font-medium text-black transition-opacity hover:opacity-90 disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Send project brief
            </button>
          </div>
        </AnimateOnScroll>
      </form>

      <!-- Success message (hidden by default) -->
      <div id="form-success" class="hidden py-12">
        <p class="text-lg font-medium text-white">Thank you!</p>
        <p class="mt-2 text-text-secondary">We'll review your brief and be in touch within 24 hours.</p>
      </div>

      <!-- Error message (hidden by default) -->
      <div id="form-error" class="hidden mt-6 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-3">
        <p class="text-sm text-red-400" id="form-error-text">Something went wrong. Please try again.</p>
      </div>
    </div>
  </section>

  <script>
    // --- Project type card selection ---
    const cards = document.querySelectorAll('.project-type-card');
    const hiddenInput = document.getElementById('project-type') as HTMLInputElement;

    cards.forEach((card) => {
      card.addEventListener('click', () => {
        // Deselect all
        cards.forEach((c) => {
          c.classList.remove('border-white/30', 'bg-white/[0.05]');
          c.classList.add('border-white/10');
        });
        // Select this one
        card.classList.remove('border-white/10');
        card.classList.add('border-white/30', 'bg-white/[0.05]');
        // Update hidden input
        if (hiddenInput) {
          hiddenInput.value = (card as HTMLElement).dataset.value || '';
        }
      });
    });

    // --- Form submission ---
    const form = document.getElementById('start-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const successDiv = document.getElementById('form-success');
    const errorDiv = document.getElementById('form-error');
    const errorText = document.getElementById('form-error-text');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Hide previous messages
      errorDiv?.classList.add('hidden');

      // Loading state
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Sending...';
      }

      // Collect form data
      const formData = new FormData(form);
      const data = {
        _honey: formData.get('_honey') || '',
        source: 'start',
        projectType: formData.get('projectType') || '',
        description: formData.get('description') || '',
        timeline: formData.get('timeline') || '',
        budget: formData.get('budget') || '',
        name: formData.get('name') || '',
        email: formData.get('email') || '',
        company: formData.get('company') || '',
        message: formData.get('description') || '',
      };

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (res.ok && result.success) {
          // Track conversion
          if (window.plausible) plausible('Project Brief Submitted');
          // Success — hide form, show thank-you
          form.classList.add('hidden');
          successDiv?.classList.remove('hidden');
        } else {
          // Server returned an error
          if (errorText) {
            errorText.textContent = result.error || 'Something went wrong. Please try again.';
          }
          errorDiv?.classList.remove('hidden');
        }
      } catch {
        // Network error
        if (errorText) {
          errorText.textContent = 'Network error. Please check your connection and try again.';
        }
        errorDiv?.classList.remove('hidden');
      } finally {
        // Reset button
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send project brief';
        }
      }
    });
  </script>
</BaseLayout>
