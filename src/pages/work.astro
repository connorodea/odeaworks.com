---

<BaseLayout title="Work | Odea Works" description="Real projects built by Odea Works across AI, engineering, and software development.">

  <!-- Hero -->
  <section class="py-32 lg:py-40">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <h1 class="text-5xl font-semibold tracking-tight text-white lg:text-6xl">
          Work
        </h1>
        <p class="mt-6 text-xl text-[#ababab]">
          {aiProjects.length + softwareProjects.length + infraProjects.length} projects across AI, software, and infrastructure.
        </p>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- Project grid -->
  <section class="pb-32 lg:pb-40">
    <div class="mx-auto max-w-5xl px-6">

      {sections.map((section) => (
        <div class="mb-20">
          <AnimateOnScroll animation="fade-up">
            <div class="border-t border-white/10 pt-8 mb-10">
              <span class="text-sm text-[#666] uppercase tracking-wider">
                {section.label}
              </span>
            </div>
          </AnimateOnScroll>

          <AnimateOnScroll animation="stagger" class="grid gap-8 md:grid-cols-2">
            {section.projects.map((project) => (
              <article class="group overflow-hidden rounded-xl bg-[#0a0a0a] transition-colors duration-300 hover:bg-[#111]">
                {project.image ? (
                  <img src={project.image} alt={project.title} class="aspect-video w-full rounded-t-xl object-cover" loading="lazy" />
                ) : (
                  <ProjectPlaceholder title={project.title} category={project.category} rounded="t-xl" />
                )}
                <div class="p-6">
                  <span class="text-xs text-[#666] uppercase tracking-wider">
                    {project.category}
                  </span>
                  <h3 class="mt-2 text-lg font-medium text-white">
                    {project.title}
                  </h3>
                  <p class="mt-2 text-sm text-[#ababab] line-clamp-2">
                    {project.description}
                  </p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {project.tags.map((tag) => (
                      <span class="rounded-full border border-white/10 px-2.5 py-0.5 text-xs text-[#666]">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <div class="mt-5 flex items-center gap-4">
                    {project.github && (
                      <a
                        href={project.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm text-[#666] transition-colors duration-200 hover:text-white"
                      >
                        GitHub &rarr;
                      </a>
                    )}
                    {project.live && (
                      <a
                        href={project.live}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-sm text-[#10a37f] transition-colors duration-200 hover:text-white"
                      >
                        Live Demo &rarr;
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </AnimateOnScroll>
        </div>
      ))}

      <!-- CTA -->
      <AnimateOnScroll animation="fade-up">
        <div class="mt-12 border-t border-white/10 pt-20 text-center">
          <h2 class="text-3xl font-semibold tracking-tight text-white">
            Have a project in mind?
          </h2>
          <div class="mt-8">
            <a
              href="/contact"
              class="inline-block rounded-full bg-white px-8 py-3 text-sm font-medium text-black transition-opacity duration-200 hover:opacity-80"
            >
              Get in touch
            </a>
          </div>
        </div>
      </AnimateOnScroll>

    </div>
  </section>

</BaseLayout>
