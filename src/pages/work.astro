---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimateOnScroll from '../components/shared/AnimateOnScroll.astro';

interface Project {
  title: string;
  category: string;
  description: string;
  tags: string[];
}

const aiProjects: Project[] = [
  {
    title: "Vidmation",
    category: "AI / Video",
    description: "AI-powered faceless YouTube video automation with narration, captions, and publishing.",
    tags: ["Python", "FastAPI", "Claude API", "FFmpeg"],
  },
  {
    title: "ClawdHub",
    category: "AI / Developer Tools",
    description: "Interactive terminal IDE for real-time Claude Code agent orchestration. 13K lines.",
    tags: ["Python", "Textual", "Claude SDK"],
  },
  {
    title: "QuickVisionz",
    category: "AI / Computer Vision",
    description: "YOLO-based computer vision pipeline for automated product sorting and barcode classification.",
    tags: ["Python", "YOLO", "OpenCV"],
  },
  {
    title: "AI Schematic Generator",
    category: "AI / Hardware",
    description: "Generate electronic circuit schematics from natural language descriptions using Claude 3.5.",
    tags: ["Python", "Claude API", "Electronics"],
  },
  {
    title: "GRIDIRON",
    category: "AI / Sports",
    description: "Custom YOLO8 model trained on football footage for real-time player and formation detection.",
    tags: ["JavaScript", "YOLO8", "ML"],
  },
  {
    title: "AI Call Spread Trader",
    category: "AI / Fintech",
    description: "AI-assisted options trading platform combining quantitative analysis with intelligent execution.",
    tags: ["Python", "Finance", "ML"],
  },
  {
    title: "AI Real Estate Assistant",
    category: "AI / SaaS",
    description: "AI-powered property search and real estate advisory platform with intelligent recommendations.",
    tags: ["Python", "AI", "SaaS"],
  },
  {
    title: "AI YouTube Analyzer",
    category: "AI / Media",
    description: "Conversational interface for analyzing YouTube videos — talk with any video and extract insights.",
    tags: ["TypeScript", "AI", "YouTube API"],
  },
];

const softwareProjects: Project[] = [
  {
    title: "QuickLotz WMS",
    category: "Enterprise / SaaS",
    description: "Enterprise warehouse management for inventory, logistics, and real-time analytics.",
    tags: ["TypeScript", "React", "PostgreSQL"],
  },
  {
    title: "LiqOS",
    category: "Enterprise / TUI",
    description: "Bloomberg Terminal-style inventory management system for liquidation operations.",
    tags: ["TypeScript", "Terminal", "PostgreSQL"],
  },
  {
    title: "Inquizit",
    category: "SaaS / Education",
    description: "AI-powered assessment and quiz generation platform with instant grading.",
    tags: ["TypeScript", "Next.js", "AI"],
  },
  {
    title: "MedScribd",
    category: "Healthcare / SaaS",
    description: "Medical documentation platform with AI agent-powered note generation and management.",
    tags: ["TypeScript", "Next.js", "AI"],
  },
  {
    title: "Upscaled Dashboard",
    category: "Enterprise / Analytics",
    description: "Real-time business intelligence dashboard for distribution and logistics operations.",
    tags: ["TypeScript", "React", "Charts"],
  },
  {
    title: "QuickReturnz",
    category: "Enterprise / WMS",
    description: "Returns and RMA management system for the QuickSuite warehouse platform.",
    tags: ["TypeScript", "React", "PostgreSQL"],
  },
  {
    title: "EbayAutolister",
    category: "E-commerce / Automation",
    description: "Production-ready eBay listing automation CLI with GitHub-style navigation and bulk operations.",
    tags: ["Python", "eBay API", "CLI"],
  },
];

const infraProjects: Project[] = [
  {
    title: "AgentAgent",
    category: "Infrastructure / AI",
    description: "Multi-agent orchestration system for Claude Code using tmux for parallel execution.",
    tags: ["Shell", "tmux", "Python"],
  },
  {
    title: "Upscaled Outreach",
    category: "Automation / B2B",
    description: "Automated supplier discovery and outreach pipeline with campaign management.",
    tags: ["Python", "FastAPI", "Next.js"],
  },
  {
    title: "QuickLotz Logistics",
    category: "Infrastructure / Ops",
    description: "End-to-end logistics and freight management for liquidation distribution operations.",
    tags: ["TypeScript", "React", "PostgreSQL"],
  },
  {
    title: "GoDaddy CLI",
    category: "Developer Tools",
    description: "Beautiful command-line interface for managing domains and DNS via the GoDaddy API.",
    tags: ["Shell", "GoDaddy API", "CLI"],
  },
  {
    title: "UPC Database Scrapers",
    category: "Data Engineering",
    description: "Scalable product data collection pipeline for barcode and UPC database aggregation.",
    tags: ["TypeScript", "Web Scraping", "Data"],
  },
];

const sections = [
  { label: "AI & Machine Learning", projects: aiProjects },
  { label: "Software Engineering", projects: softwareProjects },
  { label: "Infrastructure & Tools", projects: infraProjects },
];
---

<BaseLayout title="Work | Odea Works" description="Real projects built by Odea Works across AI, engineering, and software development.">

  <!-- Hero -->
  <section class="py-32 lg:py-40">
    <div class="mx-auto max-w-5xl px-6">
      <AnimateOnScroll animation="fade-up">
        <h1 class="text-5xl font-semibold tracking-tight text-white lg:text-6xl">
          Work
        </h1>
        <p class="mt-6 text-xl text-[#ababab]">
          Things we've built.
        </p>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- Project grid -->
  <section class="pb-32 lg:pb-40">
    <div class="mx-auto max-w-5xl px-6">

      {sections.map((section) => (
        <div class="mb-20">
          <AnimateOnScroll animation="fade-up">
            <div class="border-t border-white/10 pt-8 mb-10">
              <span class="text-sm text-[#666] uppercase tracking-wider">
                {section.label}
              </span>
            </div>
          </AnimateOnScroll>

          <AnimateOnScroll animation="stagger" class="grid gap-8 md:grid-cols-2">
            {section.projects.map((project) => (
              <article class="overflow-hidden rounded-xl bg-[#0a0a0a]">
                <div class="aspect-video w-full rounded-t-xl bg-[#141414]"></div>
                <div class="p-6">
                  <span class="text-xs text-[#666] uppercase tracking-wider">
                    {project.category}
                  </span>
                  <h3 class="mt-2 text-lg font-medium text-white">
                    {project.title}
                  </h3>
                  <p class="mt-2 text-sm text-[#ababab] line-clamp-2">
                    {project.description}
                  </p>
                  <div class="mt-4 flex flex-wrap gap-2">
                    {project.tags.map((tag) => (
                      <span class="rounded-full border border-white/10 px-2.5 py-0.5 text-xs text-[#666]">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </AnimateOnScroll>
        </div>
      ))}

      <!-- CTA -->
      <AnimateOnScroll animation="fade-up">
        <div class="mt-12 border-t border-white/10 pt-20 text-center">
          <h2 class="text-3xl font-semibold tracking-tight text-white">
            Have a project in mind?
          </h2>
          <div class="mt-8">
            <a
              href="/contact"
              class="inline-block rounded-full bg-white px-8 py-3 text-sm font-medium text-black transition-opacity duration-200 hover:opacity-80"
            >
              Get in touch
            </a>
          </div>
        </div>
      </AnimateOnScroll>

    </div>
  </section>

</BaseLayout>
