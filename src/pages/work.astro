---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'ClawdHub',
    description:
      'Terminal-native IDE and AI agent visualizer. Real-time monitoring, session replay, and deep introspection into Claude agent workflows.',
    tech: ['Python', 'AI', 'TUI'],
  },
  {
    title: 'QuickLotz WMS',
    description:
      'Full-featured warehouse management system for liquidation operations. Tracks shipments, inventory, sorting, pricing, and fulfillment.',
    tech: ['TypeScript', 'React', 'PostgreSQL'],
  },
  {
    title: 'QuickVisionz',
    description:
      'Computer vision sorting system that identifies, classifies, and routes products in real time. Reduces manual inspection and increases accuracy.',
    tech: ['Python', 'YOLO', 'OpenCV'],
  },
  {
    title: 'Vidmation',
    description:
      'AI video automation platform that generates, edits, and publishes video content at scale. Script generation through final render.',
    tech: ['Next.js', 'Python', 'FFmpeg'],
  },
  {
    title: 'LiquidationOS',
    description:
      'End-to-end operations platform integrating sourcing, manifesting, inventory, sales channels, and analytics into a single system.',
    tech: ['TypeScript', 'React'],
  },
  {
    title: 'AgentAgent',
    description:
      'Multi-agent orchestration framework coordinating autonomous Claude agents across complex, multi-step workflows with graceful failure handling.',
    tech: ['Python', 'Claude Code'],
  },
];
---

<BaseLayout title="Work | Odea Works" description="Real projects built by Odea Works across AI, engineering, and software development.">

  <!-- Hero -->
  <section class="py-32 lg:py-40">
    <div class="mx-auto max-w-5xl px-6">
      <h1 class="text-5xl font-semibold tracking-tight text-white lg:text-6xl">
        Work
      </h1>
      <p class="mt-6 text-xl text-text-secondary">
        Things we've built.
      </p>
    </div>
  </section>

  <!-- Project grid -->
  <section class="pb-32 lg:pb-40">
    <div class="mx-auto max-w-5xl px-6">
      <div class="grid gap-12 md:grid-cols-2">
        {projects.map((project) => (
          <article class="overflow-hidden rounded-xl bg-surface-2">
            <div class="aspect-video w-full bg-surface-3"></div>
            <div class="p-8">
              <h3 class="text-xl font-medium text-white">
                {project.title}
              </h3>
              <p class="mt-3 text-sm text-text-secondary leading-relaxed">
                {project.description}
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                {project.tech.map((t) => (
                  <span class="rounded-full border border-white/10 px-2 py-0.5 text-xs text-text-muted">
                    {t}
                  </span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
